namespace Inertia\Testing {

class AssertableInertia
{
    /**
     * @param  \Illuminate\Testing\TestResponse<\Illuminate\Http\Response>  $response
     */
    public static function fromTestResponse(\Illuminate\Testing\TestResponse $response): self {}

    /**
     * @return array<string, mixed>
     */
    public function toArray(): array {}

    public function component(?string $value = null, mixed $shouldExist = null): static {}

    public function url(string $value): static {}

    public function has(mixed $key, mixed $length = null, ?\Closure $callback = null): static {}

    public function where(string $key, mixed $expected): static {}

    public function missing(string $key): static {}

    public function etc(): static {}

    public function first(\Closure $callback): static {}
}

class TestResponseMacros
{
    /**
     * @return \Closure((\Closure(\Inertia\Testing\AssertableInertia): mixed)|null): \Illuminate\Testing\TestResponse<\Symfony\Component\HttpFoundation\Response>
     */
    public function assertInertia(): \Closure {}

    /**
     * @return \Closure(string|null): mixed
     */
    public function inertiaProps(): \Closure {}

    /**
     * @return \Closure(): array<string, mixed>
     */
    public function inertiaPage(): \Closure {}
}

}

namespace Illuminate\Testing {

/**
 * @template TResponse of \Symfony\Component\HttpFoundation\Response
 */
class TestResponse
{
    /**
     * @var \Symfony\Component\HttpFoundation\ResponseHeaderBag
     */
    public $headers;

    /**
     * @param  \Closure(\Inertia\Testing\AssertableInertia): mixed|null  $callback
     */
    public function assertInertia(?\Closure $callback = null): static {}

    public function getContent(): string {}

    public function getStatusCode(): int {}

    public function assertOk(): static {}

    public function assertSuccessful(): static {}

    public function assertForbidden(): static {}

    public function assertBadRequest(): static {}

    public function assertStatus(int $status): static {}

    /**
     * @param  array<string, mixed>  $data
     */
    public function assertJson(array $data): static {}
}

class PendingCommand
{
    public function assertSuccessful(): static {}

    public function expectsOutput(string $output): static {}

    public function expectsOutputToContain(string $string): static {}

    public function run(): int {}
}

}

