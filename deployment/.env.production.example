# Production .env changes for Hetzner VPS
# Copy your existing .env from Laravel Cloud and update these values:

APP_URL=https://familyfunds.app

# Database — PostgreSQL on the same VPS
DB_CONNECTION=pgsql
DB_HOST=127.0.0.1
DB_PORT=5432
DB_DATABASE=contribution_tracker
DB_USERNAME=app_user
DB_PASSWORD=<your-secure-password>

# These stay the same (database-backed, no Redis needed)
CACHE_STORE=database
QUEUE_CONNECTION=database
SESSION_DRIVER=database

# Keep your existing values for these:
# PAYSTACK_SECRET_KEY=<keep-from-laravel-cloud>
# PAYSTACK_PUBLIC_KEY=<keep-from-laravel-cloud>
# PAYSTACK_WEBHOOK_SECRET=<keep-from-laravel-cloud>
# MAIL_MAILER=<keep-from-laravel-cloud>
# RESEND_API_KEY=<keep-from-laravel-cloud>
# MAIL_FROM_ADDRESS=<keep-from-laravel-cloud>
# MAIL_FROM_NAME=<keep-from-laravel-cloud>
